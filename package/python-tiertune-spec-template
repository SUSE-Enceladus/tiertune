%{!?_defaultdocdir: %global _defaultdocdir %{_datadir}/doc}

%if 0%{?suse_version} && 0%{?suse_version} < 1600
%global __python3 /usr/bin/python3.11
%global python3_pkgversion 311
%else
%{!?__python3: %global __python3 /usr/bin/python3}
%{!?python3_pkgversion:%global python3_pkgversion 3}
%endif

%if %{undefined python3_sitelib}
%global python3_sitelib %(%{__python3} -c "from distutils.sysconfig import get_python_lib; print(get_python_lib())")
%endif

%global pygroup Development/Languages/Python
%global sysgroup System/Management
%global develsuffix devel

Name:           python-tiertune
Version:        %%VERSION
Release:        0
Summary:        TierTune - Configure cloud instances
License:        GPL-3.0-or-later
Url:            https://github.com/SUSE-Enceladus/tiertune
Group:          %{pygroup}
Source:         %{name}.tar.gz
Source1:        %{name}-rpmlintrc
BuildRoot:      %{_tmppath}/%{name}-%{version}-build
BuildRequires:  python%{python3_pkgversion}-%{develsuffix} >= 3.11
BuildRequires:  python%{python3_pkgversion}-build
BuildRequires:  python%{python3_pkgversion}-installer
BuildRequires:  python%{python3_pkgversion}-poetry-core >= 1.2.0
BuildRequires:  python%{python3_pkgversion}-wheel
BuildRequires:  python%{python3_pkgversion}-setuptools

%description
Tooling for the pubcloud team. Allows to pre-populate
containers in a distribution registry

# python3xx-tiertune
%package -n python%{python3_pkgversion}-tiertune
Summary:        TierTune - Configure cloud instances
Group:          %{pygroup}
Requires:       python%{python3_pkgversion} >= 3.11
Requires:       python%{python3_pkgversion}-setuptools
Requires:       python%{python3_pkgversion}-PyYAML

%description -n python%{python3_pkgversion}-tiertune
Configure cloud instances based on their specific instance type.

%package -n tiertune-aws
Summary:        TierTune - Configure AWS cloud instances
Group:          %{pygroup}
Requires:       python%{python3_pkgversion}-tiertune

%description -n tiertune-aws
Configure AWS cloud instances based on their specific instance type.

%package -n tiertune-azure
Summary:        TierTune - Configure Azure cloud instances
Group:          %{pygroup}
Requires:       python%{python3_pkgversion}-tiertune

%description -n tiertune-azure
Configure Azure cloud instances based on their specific instance type.

%package -n tiertune-gce
Summary:        TierTune - Configure GCE cloud instances
Group:          %{pygroup}
Requires:       python%{python3_pkgversion}-tiertune

%description -n tiertune-gce
Configure GCE cloud instances based on their specific instance type.

%prep
%autosetup -n tiertune-%{version}

# Build application wheel
%{__python3} -m build --no-isolation --wheel

%build

%install
%{__python3} -m installer --destdir %{buildroot} %{?is_deb:--no-compile-bytecode} dist/*.whl

install -d -m 755 %{buildroot}/%{_sbindir}
install -d -m 755 %{buildroot}/etc

install -d -m 755 %{buildroot}/usr/lib/systemd/system
install -m 644 systemd/tiertune-azure.service \
    %{buildroot}/usr/lib/systemd/system/tiertune-azure.service
install -m 644 systemd/tiertune-aws.service \
    %{buildroot}/usr/lib/systemd/system/tiertune-aws.service
install -m 644 systemd/tiertune-gce.service \
    %{buildroot}/usr/lib/systemd/system/tiertune-gce.service

%files -n python%{python3_pkgversion}-tiertune
%{python3_sitelib}/tiertune*

%files -n tiertune-aws
%{_bindir}/tiertune-aws
%config %{_usr}/lib/systemd/system/tiertune-aws.service

%files -n tiertune-azure
%{_bindir}/tiertune-azure
%config %{_usr}/lib/systemd/system/tiertune-azure.service

%files -n tiertune-gce
%{_bindir}/tiertune-gce
%config %{_usr}/lib/systemd/system/tiertune-gce.service

%changelog
